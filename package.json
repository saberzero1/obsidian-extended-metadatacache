{
  "name": "obsidian-extended-metadatacache",
  "version": "0.2.0",
  "description": "Inverse lookup complement to Obsidian's MetadataCache â€” tagâ†’files, backlinks, headingâ†’files, frontmatterâ†’files, and more.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
