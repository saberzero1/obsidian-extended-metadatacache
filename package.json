  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "metadata-cache",
    "inverse-index",
    "backlinks",
    "tags"
  ],
  "author": "saberzero1",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saberzero1/obsidian-extended-metadatacache.git"
  },
  "bugs": {
    "url": "https://github.com/saberzero1/obsidian-extended-metadatacache/issues"
  },
  "homepage": "https://github.com/saberzero1/obsidian-extended-metadatacache#readme",
  "peerDependencies": {
