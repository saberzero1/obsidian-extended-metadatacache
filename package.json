    "@wdio/mocha-framework": "^9.27.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "^1.8.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "wdio-obsidian-reporter": "^2.4.0",
    "wdio-obsidian-service": "^2.4.0"
  },
  "publishConfig": {
